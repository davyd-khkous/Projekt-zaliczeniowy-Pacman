class Menu:

    def __init__(self):
        self.start_game = False

    def display(self):

        background(10, 20, 80)

        textAlign(CENTER)

        fill(255, 255, 0)
        textSize(60)
        text("PAC-MAN", width / 2, 150)

        # Graj
        fill(0, 180, 0)
        rect(width/2 - 150, 300, 300, 70, 10)

        fill(255)
        textSize(30)
        text("GRAJ", width/2, 345)

        # Wyjdź
        fill(180, 0, 0)
        rect(width/2 - 150, 420, 300, 70, 10)

        fill(255)
        text("WYJDŹ Z GRY", width/2, 465)

    def mousePressed(self):

        # Graj
        if (width/2 - 150 <= mouseX <= width/2 + 150 and
            300 <= mouseY <= 370):

            self.start_game = True

        # Wyjdź
        elif (width/2 - 150 <= mouseX <= width/2 + 150 and
              420 <= mouseY <= 490):

            exit()
